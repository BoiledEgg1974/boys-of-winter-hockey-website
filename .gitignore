# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Test and tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Local environment files
.env
.env.local

# GM / admin headline image uploads (per league under static)
app/static/img/news/

# Flask/local runtime files
instance/*.db
instance/*.sqlite
instance/*.sqlite3
instance/*.bak
*.log

# Cursor IDE: ignore everything in .cursor except shared agent rules
.cursor/*
!.cursor/rules/
!.cursor/rules/**

# Local PythonAnywhere deploy wizard (machine-specific CSV paths)
scripts/pythonanywhere_csv_sources.json

# Saved-game CSV locations (created when you run STEP1_update_from_saved_game.py and save paths)
scripts/saved_game_csv_paths.json

# Editor/OS files
.vscode/
.idea/
Thumbs.db
.DS_Store

# Mobile shell (Capacitor) — dependencies and local native artifacts
mobile/node_modules/
mobile/android/.gradle/
mobile/android/app/build/
mobile/android/build/
mobile/android/local.properties
mobile/ios/App/Pods/
mobile/ios/DerivedData/
mobile/ios/**/*.xcuserstate
