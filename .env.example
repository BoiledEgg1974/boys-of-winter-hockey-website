# Copy to .env and adjust if needed
# Optional comma-separated extra addresses for admin review alerts (news, AP, hub registrations).
# Defaults to JOIN_LEAGUE_RECIPIENT only when unset.
# ADMIN_ALERT_EMAILS=you@example.com,backup@example.com
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production
# Per-league default when using app:create_app (see app/config.py). Multi-site run uses wsgi.py and instance/<slug>.db.
LEAGUE_SLUG=bowl-fantasy
DATABASE_URL=sqlite:///instance/bowl-fantasy.db
# SQLite busy lock wait (seconds) for SQLAlchemy connect timeout; default 30. Raise if you still see database is locked under load.
# SQLITE_BUSY_TIMEOUT_SECONDS=45
# Same value must be set on each Discord bot that calls /api/discord/events/* (header X-Discord-Events-Secret).
# Generate e.g. Python: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Defaults to bowluniverse in app/config.py when unset; set explicitly in production.
# DISCORD_EVENTS_SHARED_SECRET=bowluniverse
#
# Unified Discord delivery bot (scripts/league_discord_bot) — one process, all three leagues.
# DISCORD_BOT_TOKEN=
# DISCORD_BOT_NAME=league-discord-bot
# DISCORD_BOT_VERSION=1.0.0
# DISCORD_BOT_POLL_SECONDS=8
# DISCORD_BOT_DELIVERY_DELAY_SECONDS=1.2
# DISCORD_BOT_MAX_MESSAGE_PARTS=4
# DISCORD_BOT_SITE_TIMEOUT_SECONDS=90
# DISCORD_BOT_LEAGUE_BASE_URLS=bowl-historical:https://www.bowlhockey.com/bowl-historical,bowl-fantasy:https://www.bowlhockey.com/bowl-fantasy,bowl-cap:https://www.bowlhockey.com/bowl-cap
# Required on PythonAnywhere in boys-of-winter-hockey-website/.env (web app + Always-on bot).
# Without this, Discord event payloads get no embed link (relative paths are rejected by Discord).
SITE_PUBLIC_BASE_URL=https://www.bowlhockey.com
#
# Draft Hub desk: optional OpenAI via TRADE_AI_OPENAI_API_KEY (and TRADE_AI_OPENAI_MODEL).
# Set to 1/true/yes/on to force rules-based suggestions only (no OpenAI), e.g. under load.
# DRAFT_HUB_AI_HEURISTIC_ONLY=1
